<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>标签: <%= tagName %> - 我的个人博客</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header class="header">
    <div class="container header-inner">
      <a href="/" class="brand-mark gradient-button" aria-label="Poppis">
        <span class="gradient-text">Poppis</span>
      </a>
      <div class="header-content">
        <div class="brand-block">
          <p class="brand-kicker">Tag Archive</p>
          <h1 class="logo"><a href="/">我的博客</a></h1>
        </div>
        <nav class="nav">
          <a href="/">首页</a>
          <a href="/about">关于我</a>
          <% if (user) { %>
            <a href="/poppis-console/dashboard">后台管理</a>
          <% } %>
        </nav>
      </div>
    </div>
  </header>

  <main class="main">
    <div class="container">
      <section class="page-hero">
        <p class="section-kicker">Tag</p>
        <h1 class="page-title"><%= tagName %></h1>
        <p class="page-summary">标签更轻量，适合横向浏览内容中的关键词和细分议题。</p>
      </section>

      <% if (posts.length > 0) { %>
        <div class="posts-grid">
          <% posts.forEach(post => { %>
            <article class="post-card">
              <% if (post.cover_image) { %>
                <div class="post-cover-container">
                  <img src="<%= post.cover_image %>" alt="<%= post.title %>" class="post-cover loaded">
                </div>
              <% } %>
              <div class="post-content">
                <div class="post-meta">
                  <% if (post.category_name) { %>
                    <span class="category"><%= post.category_name %></span>
                  <% } %>
                  <span class="date"><%= new Date(post.created_at).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
                </div>
                <h2 class="post-title">
                  <a href="/post/<%= post.slug %>"><%= post.title %></a>
                </h2>
                <% if (post.excerpt) { %>
                  <p class="post-excerpt"><%= post.excerpt %></p>
                <% } %>
              </div>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <div class="empty-state">
          <p class="empty-kicker">Empty tag</p>
          <h2>这个标签下暂时还没有内容</h2>
          <p>可以先回到首页，从最新更新开始读。</p>
          <a href="/" class="btn btn-primary">返回首页</a>
        </div>
      <% } %>
    </div>
  </main>

  <footer class="footer">
    <div class="container footer-grid">
      <div>
        <p class="footer-kicker">Reading trail</p>
        <h3>标签适合串联那些跨分类的小主题。</h3>
      </div>
      <div class="footer-links">
        <a href="/">首页</a>
        <a href="/about">关于我</a>
      </div>
      <p class="footer-copy">&copy; 2026 我的个人博客.</p>
      <p class="footer-copy footer-beian">
        <a href="https://beian.mps.gov.cn/#/query/webSearch?code=61030402000136" rel="noreferrer" target="_blank" class="beian-link">
          <img src="/images/beian-badge.svg" alt="公安备案图标" class="beian-icon">
          <span>陕公网安备61030402000136号</span>
        </a>
      </p>
    </div>
  </footer>
</body>
</html>
