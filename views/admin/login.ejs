<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>登录 - 后台管理</title>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <div class="login-container">
    <div class="login-box">
      <a href="/" class="admin-brand-mark admin-brand-mark-large gradient-button" aria-label="Poppis">
        <span class="gradient-text">Poppis</span>
      </a>
      <p class="admin-kicker">Editor Access</p>
      <h1>进入内容工作台</h1>
      <p class="login-note">登录后可以维护文章、分类、标签以及关于页面内容。</p>
      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>
      <form method="POST" action="/poppis-console/login">
        <div class="form-group">
          <label for="username">用户名</label>
          <input type="text" id="username" name="username" required>
        </div>
        <div class="form-group">
          <label for="password">密码</label>
          <input type="password" id="password" name="password" required>
        </div>
        <button type="submit" class="btn btn-primary">登录</button>
      </form>
    </div>
  </div>
</body>
</html>
