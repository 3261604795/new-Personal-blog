<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= categoryName %> - 我的个人博客</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header class="header">
    <div class="container header-inner">
      <a href="/" class="brand-mark gradient-button" aria-label="Poppis">
        <span class="gradient-text">Poppis</span>
      </a>
      <div class="header-content">
        <div class="brand-block">
          <p class="brand-kicker">Category Archive</p>
          <h1 class="logo"><a href="/">我的博客</a></h1>
        </div>
        <nav class="nav">
          <a href="/">首页</a>
          <a href="/about">关于我</a>
          <% if (user) { %>
            <a href="/poppis-console/dashboard">后台管理</a>
          <% } %>
        </nav>
      </div>
    </div>
  </header>

  <main class="main">
    <div class="container">
      <section class="page-hero">
        <p class="section-kicker">Category</p>
        <h1 class="page-title"><%= categoryName %></h1>
        <p class="page-summary">同一主题下的内容被收拢在一起，方便连续阅读和查找。</p>
      </section>

      <% if (posts.length > 0) { %>
        <div class="posts-grid">
          <% posts.forEach(post => { %>
            <article class="post-card">
              <% if (post.cover_image) { %>
                <div class="post-cover-container">
                  <img src="<%= post.cover_image %>" alt="<%= post.title %>" class="post-cover loaded">
                </div>
              <% } %>
              <div class="post-content">
                <div class="post-meta">
                  <span class="date"><%= new Date(post.created_at).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
                  <span class="read-time"><%= Math.ceil(post.content.length / 400) %> 分钟阅读</span>
                </div>
                <h2 class="post-title">
                  <a href="/post/<%= post.slug %>"><%= post.title %></a>
                </h2>
                <% if (post.excerpt) { %>
                  <p class="post-excerpt"><%= post.excerpt %></p>
                <% } %>
              </div>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <div class="empty-state">
          <p class="empty-kicker">Empty category</p>
          <h2>这个分类暂时还没有文章</h2>
          <p>你可以先回首页看看最近更新的内容。</p>
          <a href="/" class="btn btn-primary">返回首页</a>
        </div>
      <% } %>
    </div>
  </main>

  <footer class="footer">
    <div class="container footer-grid">
      <div>
        <p class="footer-kicker">Archive</p>
        <h3>主题归档帮助内容形成上下文。</h3>
      </div>
      <div class="footer-links">
        <a href="/">首页</a>
        <a href="/about">关于我</a>
      </div>
      <p class="footer-copy">&copy; 2026 我的个人博客.</p>
    </div>
  </footer>
</body>
</html>
